# Copy this file to .env.local for local development.
# On Render, set these as environment variables in the dashboard
# (render.yaml handles this for you when using the Blueprint flow).

# ── Next.js / NextAuth ────────────────────────────────────────────────────────

# The canonical public URL of the app (no trailing slash).
# Local:      http://localhost:3000
# Production: https://<your-app>.onrender.com
NEXTAUTH_URL=http://localhost:3000

# Random 32-character secret for signing JWT sessions.
# Generate one: openssl rand -base64 32
NEXTAUTH_SECRET=your-nextauth-secret-here

# ── MongoDB ───────────────────────────────────────────────────────────────────

# MongoDB Atlas connection string.
# In Atlas: Network Access → Add IP Address → Allow from anywhere (0.0.0.0/0)
# because Render uses dynamic IP addresses.
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# ── Cloudinary (image uploads) ────────────────────────────────────────────────

CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ── Groq (AI-powered predictions) ────────────────────────────────────────────

GROQ_API_KEY=your-groq-api-key

# ── Internal endpoint secrets ─────────────────────────────────────────────────

# Sent as the x-cron-secret header by the Render cron job.
# Generate: openssl rand -hex 32
CRON_SECRET=your-cron-secret-here

# Protects the seed endpoint (admin/seed). Only needed during development.
SEED_SECRET=your-seed-secret-here
